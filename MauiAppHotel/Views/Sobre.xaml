<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppHotel.Views.Sobre"
             Title="Sobre"
             BackgroundColor="Purple" >

    <ScrollView>
        
        <VerticalStackLayout Padding="20" Spacing="15" HorizontalOptions="Center">

            <Image Source="header_hotel.png" 
       HeightRequest="250"
       Aspect="AspectFit"
       Margin="0,0,0,20" />

            <Label Text="App Hotel - Mergulhando no Tema"
                   FontSize="22"
                   TextColor="White"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <Frame BackgroundColor="#2D0066" BorderColor="#B026FF" CornerRadius="15">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Desenvolvido por: José Guilherme Paixão de Oliveira." 
                           TextColor="White" 
                           FontSize="18" />
                    <Label Text="Ano: 2026 " 
                           TextColor="#D1D1D1" 
                           FontSize="16" />
                    <Label Text="Tecnologia: .NET MAUI DESENVOLVIMENTO DE SISTEMAS" 
                           TextColor="#D1D1D1" 
                           FontSize="16" />
                </VerticalStackLayout>
            </Frame>

            <Button Text="Voltar" Clicked="Button_Clicked"/>

        </VerticalStackLayout>
       
    </ScrollView>
</ContentPage>
 